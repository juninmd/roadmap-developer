{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "types": ["vitest/globals"]
  },
  "include": [
    "utils/**/*.ts",
    "tests/**/*.ts",
    "tests-e2e/**/*.ts",
    ".vitepress/**/*.ts",
    "eslint.config.ts"
  ],
  "exclude": ["node_modules", ".vitepress/dist", ".vitepress/cache"]
}
