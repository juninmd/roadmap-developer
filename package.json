{
  "name": "roadmap-developer-2026",
  "version": "1.0.4",
  "description": "Guia para desenvolvedores completo e atualizado para 2026. Transformado em site estático com VitePress.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "docs:dev": "vitepress dev",
    "docs:build": "vitepress build",
    "docs:preview": "vitepress preview",
    "lint": "eslint . --ext .js,.cjs,.mjs,.vue",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\"",
    "format": "prettier --write .",
    "test": "vitest run tests/unit --coverage",
    "test:e2e": "playwright test"
  },
  "keywords": [
    "roadmap",
    "developer",
    "2026",
    "backend",
    "frontend",
    "mobile",
    "devops",
    "ai",
    "learning-path"
  ],
  "author": "Roadmap Developer Community",
  "license": "MIT",
  "dependencies": {
    "mermaid": "10.9.3",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^10.8.0",
    "markdownlint-cli2": "^0.22.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "vitest": "^4.1.1"
  }
}
