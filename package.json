  "description": "Guia para desenvolvedores completo e atualizado para 2026. Transformado em site estático com VitePress.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "docs:dev": "vitepress dev",
    "docs:build": "vitepress build",
    "docs:preview": "vitepress preview",
